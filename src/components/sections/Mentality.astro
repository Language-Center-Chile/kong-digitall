---
// src/components/sections/Mentality.astro
---

<section id="mentality" class="py-32 relative overflow-hidden flex flex-col items-center justify-center">
  <!-- Background huge text -->
  <div class="absolute inset-0 flex flex-col items-center justify-center opacity-5 select-none pointer-events-none z-0 overflow-hidden w-full">
    <h2 class="font-heading font-black text-[20vw] leading-[0.8] text-kong-yellow uppercase text-center whitespace-nowrap overflow-hidden text-outline">
      PRIMAL<br />POWER
    </h2>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center w-full">
    <span class="text-kong-yellow font-bold text-sm tracking-[0.3em] uppercase mb-6 inline-block">THE MENTALITY</span>
    
    <h2 class="font-heading font-black text-5xl md:text-7xl lg:text-[5.5rem] leading-none uppercase tracking-tight mb-20 italic">
      <span class="text-white drop-shadow-md">WE DON'T COMPETE.</span><br />
      <span class="text-kong-yellow drop-shadow-md">WE ELIMINATE.</span>
    </h2>

    <div class="w-full max-w-3xl space-y-12 text-left">
      <!-- Item 01 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start group">
        <span class="font-heading font-black text-5xl md:text-6xl text-kong-yellow leading-none shrink-0 group-hover:scale-110 transition-transform">01</span>
        <div>
          <h4 class="font-bold text-kong-yellow text-xl mb-2 tracking-wide uppercase">INSTINCTIVE INNOVATION:</h4>
          <p class="text-white text-lg leading-relaxed">
            We move faster than the market. Our strategies are rooted in core psychological drivers and executed with cutting-edge tech.
          </p>
        </div>
      </div>

      <!-- Item 02 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start group">
        <span class="font-heading font-black text-5xl md:text-6xl text-kong-yellow leading-none shrink-0 group-hover:scale-110 transition-transform">02</span>
        <div>
          <h4 class="font-bold text-kong-yellow text-xl mb-2 tracking-wide uppercase">RAW EFFICIENCY:</h4>
          <p class="text-white text-lg leading-relaxed">
            No fluff. No corporate jargon. Just high-impact results that translate directly into digital dominance.
          </p>
        </div>
      </div>

      <!-- Item 03 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start group">
        <span class="font-heading font-black text-5xl md:text-6xl text-kong-yellow leading-none shrink-0 group-hover:scale-110 transition-transform">03</span>
        <div>
          <h4 class="font-bold text-kong-yellow text-xl mb-2 tracking-wide uppercase">SOVEREIGN RESULTS:</h4>
          <p class="text-white text-lg leading-relaxed">
            We build digital ecosystems that you own entirely. No platform dependency, just pure sovereign power.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>