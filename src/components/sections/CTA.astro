---
// src/components/sections/CTA.astro
---

<section id="cta" class="py-32 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto">
  <div class="relative border border-kong-yellow p-12 md:p-24 text-center group overflow-hidden">
    
    <!-- Top Left Corner Square -->
    <div class="absolute -top-3 -left-3 w-6 h-6 bg-kong-yellow transition-transform group-hover:scale-125"></div>
    
    <!-- Bottom Right Corner Square -->
    <div class="absolute -bottom-3 -right-3 w-6 h-6 bg-kong-yellow transition-transform group-hover:scale-125"></div>

    <div class="relative z-10 flex flex-col items-center">
      <h2 class="font-heading font-black text-4xl md:text-5xl lg:text-6xl text-white uppercase tracking-tight mb-6">
        READY TO LEAD THE PACK?
      </h2>
      
      <p class="text-gray-300 text-lg md:text-xl mb-12 max-w-2xl mx-auto">
        The jungle doesn't wait for the weak. Secure your digital territory today.
      </p>

      <a href="#contact" class="inline-block bg-kong-yellow text-kong-black font-bold px-12 py-5 text-sm md:text-base hover:bg-yellow-400 transition-all uppercase tracking-[0.2em] transform hover:-translate-y-1 hover:shadow-[0_10px_30px_-10px_rgba(255,234,0,0.5)]">
        INITIATE PROTOCOL
      </a>
    </div>
  </div>
</section>
