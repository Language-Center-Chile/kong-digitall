---
// src/components/layout/Footer.astro
---

<footer class="bg-kong-black border-t-4 border-kong-yellow py-8 mt-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      
      <!-- Left side: Brand -->
      <div class="flex flex-col gap-2 text-center md:text-left">
        <span class="font-heading font-black italic text-xl text-kong-yellow tracking-tighter">KONG DIGITAL</span>
        <span class="text-kong-gray text-xs font-bold tracking-widest uppercase">© 2026 KONG DIGITAL. PRIMAL PERFORMANCE.</span>
      </div>

      <!-- Center side: Links -->
      <div class="flex flex-wrap justify-center gap-6 font-bold text-sm tracking-widest">
        <a href="#" class="hover:text-kong-yellow transition-colors">INSTAGRAM</a>
        <a href="#" class="hover:text-kong-yellow transition-colors">TWITTER</a>
        <a href="#" class="hover:text-kong-yellow transition-colors">LINKEDIN</a>
        <a href="#" class="hover:text-kong-yellow transition-colors">PRIVACY</a>
      </div>

      <!-- Right side: Status indicator -->
      <div class="flex items-center gap-2 font-bold text-sm text-kong-yellow tracking-widest">
        <span class="w-2 h-2 rounded-full bg-kong-yellow animate-pulse"></span>
        SYSTEM ONLINE
      </div>

    </div>
  </div>
</footer>